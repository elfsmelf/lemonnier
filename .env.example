# URL that form submissions are POSTed to (e.g. a Make.com / Zapier webhook).
# Must be NEXT_PUBLIC_* because the form runs client-side.
# If unset, the form "succeeds" locally and logs the payload to the console —
# useful for local dev, but in production you must set this in Vercel env vars.
NEXT_PUBLIC_LEAD_WEBHOOK_URL=
